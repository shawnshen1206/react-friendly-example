{
  "name": "gufofaq-react-friendly-example",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm-run-all --parallel dev:*",
    "dev:html": "eleventy --serve",
    "dev:css": "sass --watch src/scss/main.scss:dist/css/main.css",
    "build": "npm-run-all build:html build:css",
    "build:html": "eleventy",
    "build:css": "sass src/scss/main.scss:dist/css/main.css --style=compressed --no-source-map"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "npm-run-all": "^4.1.5",
    "sass": "^1.80.0"
  }
}
